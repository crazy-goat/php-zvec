    ZEND_PARSE_PARAMETERS_NONE();
    zval *model = zend_read_property(zvec_qwen_embedding_ce, Z_OBJ_P(ZEND_THIS), "model", sizeof("model") - 1, 1, nullptr);
    RETURN_ZVAL(model, 1, 0);
}

