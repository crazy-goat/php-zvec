name: Build PHP Extension

on:
  pull_request:
    branches: [main]

env:
  ZVEC_VERSION: v0.2.0
  ZVEC_BUILD_RELEASE: zvec-build-v0.2.0

jobs:
  build-ext:
    if: github.event.pull_request.head.repo.full_name == github.repository
    runs-on: ubuntu-24.04
    strategy:
      matrix:
        php-version: ['8.4']

    name: ext - PHP ${{ matrix.php-version }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install system dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            build-essential cmake g++ \
            libssl-dev libz-dev \
            autoconf automake libtool \
            curl binutils

      - name: Download prebuilt zvec
        run: |
          URL="https://github.com/${GITHUB_REPOSITORY}/releases/download/${ZVEC_BUILD_RELEASE}/zvec-${ZVEC_VERSION}-ubuntu24-x86_64.tar.gz"
          echo "Downloading: $URL"
          curl -fL "$URL" -o /tmp/zvec.tar.gz

          rm -rf zvec
          tar -xzf /tmp/zvec.tar.gz

          test -f zvec/build/lib/libzvec_db.a
          test -d zvec/src/include
          test -d zvec/thirdparty/sparsehash/sparsehash-2.0.4/src

      - name: Setup PHP
        uses: shivammathur/setup-php@v2
        with:
          php-version: ${{ matrix.php-version }}
          tools: phpize

      - name: Build PHP extension
        working-directory: php-ext
        run: |
          phpize
          ./configure --enable-zvec
          make -j$(nproc)

      - name: Re-link with whole-archive (libtool workaround)
        working-directory: php-ext
        run: |
          ZVEC_LIB="../zvec/build/lib"
          ZVEC_EXT_LIB="../zvec/build/external/usr/local/lib"
          g++ -shared -fPIC -DPIC \
            .libs/*.o \
            -Wl,--whole-archive \
              $ZVEC_LIB/libzvec_db.a \
              $ZVEC_LIB/libzvec_ailego.a \
              $ZVEC_LIB/libcore_metric.a \
              $ZVEC_LIB/libcore_knn_hnsw.a \
              $ZVEC_LIB/libcore_knn_hnsw_sparse.a \
              $ZVEC_LIB/libcore_knn_flat.a \
              $ZVEC_LIB/libcore_knn_flat_sparse.a \
              $ZVEC_LIB/libcore_knn_ivf.a \
              $ZVEC_LIB/libcore_knn_cluster.a \
              $ZVEC_LIB/libcore_quantizer.a \
              $ZVEC_LIB/libcore_utility.a \
              $ZVEC_LIB/libcore_mix_reducer.a \
              $ZVEC_LIB/libcore_framework.a \
              $ZVEC_LIB/libcore_interface.a \
              $ZVEC_EXT_LIB/*.a \
            -Wl,--no-whole-archive \
            -lssl -lcrypto -lstdc++ -lz -lpthread -ldl \
            -Wl,-soname,zvec.so \
            -o modules/zvec.so

      - name: Verify extension loads
        working-directory: php-ext
        run: |
          php -n -d enable_dl=1 -d extension=modules/zvec.so -r 'if (!extension_loaded("zvec")) { echo "FAIL: zvec not loaded\n"; exit(1); } echo "zvec loaded: yes\n";'

      - name: Run tests
        env:
          TEST_PHP_ARGS: "-n -d extension=${{ github.workspace }}/php-ext/modules/zvec.so"
        run: |
          php run-tests.php -q --show-diff tests/

      - name: Upload extension artifact
        uses: actions/upload-artifact@v4
        with:
          name: zvec-php${{ matrix.php-version }}-ubuntu24-${{ runner.arch }}
          path: php-ext/modules/zvec.so

  build-ffi:
    if: github.event.pull_request.head.repo.full_name == github.repository
    runs-on: ubuntu-24.04
    strategy:
      matrix:
        php-version: ['8.4']

    name: ffi - PHP ${{ matrix.php-version }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install system dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            build-essential cmake g++ \
            libssl-dev libz-dev \
            curl

      - name: Download prebuilt zvec
        run: |
          URL="https://github.com/${GITHUB_REPOSITORY}/releases/download/${ZVEC_BUILD_RELEASE}/zvec-${ZVEC_VERSION}-ubuntu24-x86_64.tar.gz"
          echo "Downloading: $URL"
          curl -fL "$URL" -o /tmp/zvec.tar.gz

          rm -rf zvec
          tar -xzf /tmp/zvec.tar.gz

          test -f zvec/build/lib/libzvec_db.a
          test -d zvec/src/include
          test -d zvec/thirdparty/sparsehash/sparsehash-2.0.4/src

      - name: Setup PHP
        uses: shivammathur/setup-php@v2
        with:
          php-version: ${{ matrix.php-version }}
          extensions: ffi

      - name: Build FFI shared library
        working-directory: ffi
        run: |
          mkdir -p build
          cd build
          cmake ..
          make -j$(nproc)
          ls -la libzvec_ffi.so

      - name: Run tests
        env:
          TEST_PHP_ARGS: "-n -d extension=ffi"
        run: |
          php run-tests.php -q --show-diff tests/
