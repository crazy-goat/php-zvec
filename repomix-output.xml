name: Release PHP Extension

on:
  push:
    tags:
      - 'v*'

env:
  ZVEC_VERSION: v0.2.0
  ZVEC_BUILD_RELEASE: zvec-build-v0.2.0

jobs:
  create-release:
    runs-on: ubuntu-24.04
    name: Create Release

    permissions:
      contents: write

    steps:
      - name: Verify tag is on main
        run: |
          git clone --bare "https://github.com/${GITHUB_REPOSITORY}.git" /tmp/repo.git
          if ! git -C /tmp/repo.git branch --contains "${{ github.sha }}" | grep -qw main; then
            echo "ERROR: Tag ${{ github.ref_name }} is not on main branch"
            exit 1
          fi

      - name: Create release if not exists
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          gh release create "${{ github.ref_name }}" \
            --repo "${{ github.repository }}" \
            --title "${{ github.ref_name }}" \
            --generate-notes \
            || echo "Release already exists"

  release-ffi:
    needs: create-release
    runs-on: ubuntu-24.04
    name: Build & Release FFI Library

    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install system dependencies
        run: |
          sudo apt-get update
