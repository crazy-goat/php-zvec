    ZEND_ARG_TYPE_INFO_WITH_DEFAULT_VALUE(0, topn, IS_LONG, 0, "10")
    ZEND_ARG_TYPE_INFO_WITH_DEFAULT_VALUE(0, rankConstant, IS_LONG, 0, "60")
ZEND_END_ARG_INFO()

