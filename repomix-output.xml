      - name: Upload release asset
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          gh release upload "${{ github.ref_name }}" "$ASSET_NAME" --clobber

  release-ext:
    needs: create-release
    runs-on: ubuntu-24.04
    strategy:
      matrix:
        php-version: ['8.4']

    name: Build & Release PHP Extension - ${{ matrix.php-version }}

