    // Test: Insert multiple documents (batch)
    $doc2 = new ZVecDoc('doc2');
    $doc2->setInt64('id', 2)
        ->setString('name', 'Bob')
        ->setFloat('score', 87.0)
        ->setVectorFp32('embedding', [0.0, 1.0, 0.0, 0.0]);
    
