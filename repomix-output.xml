ZEND_END_ARG_INFO()

static const zend_function_entry zvec_weighted_reranker_methods[] = {
    PHP_ME(ZVecWeightedReRanker, __construct, arginfo_zvec_wr___construct, ZEND_ACC_PUBLIC)
