{
    "name": "crazy-goat/zvec",
    "description": "PHP FFI bindings for zvec vector database",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/crazy-goat/php-zvec",
    "support": {
        "issues": "https://github.com/crazy-goat/php-zvec/issues",
        "source": "https://github.com/crazy-goat/php-zvec"
    },
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*"
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\ZVec\\": "src/"
        },
        "files": [
            "php/ZVec.php",
            "php/ZVecRerankedDoc.php",
            "php/ZVecReRanker.php",
            "php/ZVecRrfReRanker.php",
            "php/ZVecWeightedReRanker.php"
        ]
    },
    "bin": [
        "bin/zvec-install"
    ],
    "minimum-stability": "stable"
}
